{
  "$schema": "https://developers.reddit.com/schema/config-file.v1.json",
  "name": "find-me-app",
  "post": {
    "dir": "dist/client",
    "entrypoints": {
      "default": {
        "entry": "splash.html",
        "height": "tall",
        "inline": true
      },
      "leaderboard": {
        "entry": "leaderboard.html",
        "height": "tall",
        "inline": true
      },
      "game": {
        "entry": "index.html",
        "height": "tall"
      },
      "create_game": {
        "entry": "create_game.html",
        "height": "tall"
      }
    }
  },
  "server": {
    "dir": "dist/server",
    "entry": "index.cjs"
  },
  "media": {},
  "triggers": {
    "onAppInstall": "/internal/on-app-install",
    "onPostDelete": "/internal/on-delete"
  },
  "dev": {
    "subreddit": "find_me_app_dev"
  },
  "permissions": {
    "http": {
      "enable": true,
      "domains": [
        "a.tile.openstreetmap.org",
        "b.tile.openstreetmap.org",
        "c.tile.openstreetmap.org"
      ]
    },
    "media": true,
    "reddit": {
      "asUser": ["SUBMIT_POST"]
    },
    "redis": true
  },
  "menu": {
    "items": [
      {
        "label": "Create leaderboard",
        "description": "Creates leaderboard that shows points that a player accumulated over time",
        "forUserType": "moderator",
        "location": ["subreddit"],
        "endpoint": "/internal/menu/create-leaderboard",
        "postFilter": "none"
      }
    ]
  }
}